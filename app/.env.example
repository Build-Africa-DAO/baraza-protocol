# ─────────────────────────────────────────────────────────────
# Baraza Protocol — Environment Variables
# Copy to .env.local for local development. Never commit real secrets.
#
# Legend:
#   [REQUIRED]  — app will fail or behave incorrectly without this
#   [OPTIONAL]  — feature degrades gracefully when unset
#   [CLIENT]    — exposed to the browser (VITE_ prefix)
#   [SERVER]    — server-side only, never sent to the browser
# ─────────────────────────────────────────────────────────────


# ─── APP ──────────────────────────────────────────────────────
# [REQUIRED][CLIENT] Public URL of the deployed app
VITE_SITE_URL=https://baraza-protocol.vercel.app


# ─── SUPABASE ─────────────────────────────────────────────────
# [REQUIRED][CLIENT] Supabase project URL and anon key (safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# [REQUIRED][SERVER] Service role key — bypasses RLS, never expose to browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# ─── STELLAR / BRZA ───────────────────────────────────────────
# [REQUIRED][SERVER] Network: testnet | mainnet
STELLAR_NETWORK=mainnet
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-rpc.mainnet.stellar.gateway.fm

# [REQUIRED][SERVER] Treasury G-account that receives membership payments
STELLAR_TREASURY_ACCOUNT=

# [REQUIRED][SERVER] 32+ byte random secret for signing payment intent tokens
# Generate: openssl rand -hex 32
STELLAR_INTENT_SECRET=


# [REQUIRED][CLIENT] Mirror of server-side Stellar config for client reads
VITE_STELLAR_NETWORK=mainnet
VITE_STELLAR_HORIZON_URL=https://horizon.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
VITE_STELLAR_TREASURY_ACCOUNT=

# [REQUIRED][CLIENT] BRZA token issuer and distributor accounts
VITE_BRZA_ISSUER_ADDRESS=
VITE_BRZA_DISTRIBUTOR_ADDRESS=

# [SERVER mirror] — used by server-side contract clients
BRZA_ISSUER_ADDRESS=
BRZA_DISTRIBUTOR_ADDRESS=


# ─── PAYMENTS ─────────────────────────────────────────────────
# [REQUIRED][SERVER] Shared bearer token protecting /api/payments/* proxy routes
# Generate: openssl rand -hex 32
PAYMENT_ADAPTER_PROXY_SECRET=

# [REQUIRED][SERVER] HMAC pepper for hashing phone/wallet before storing
# Generate: openssl rand -hex 32
PAYMENT_PHONE_HASH_PEPPER=

# Kotani Pay — M-Pesa ↔ Stellar on/off ramp
# Sign up: https://kotanipay.com
# [REQUIRED][SERVER]
KOTANI_PAY_API_KEY=
KOTANI_API_BASE=https://api.kotanipay.com
# [REQUIRED][SERVER] Webhook signature secret (set in Kotani dashboard → Webhooks)
KOTANI_WEBHOOK_SECRET=

# Minisend — M-Pesa ↔ USDC off-ramp
# Sign up: https://minisend.xyz
# [OPTIONAL][SERVER]
MINISEND_API_KEY=
MINISEND_API_BASE=https://api.minisend.xyz


# ─── AFRICA'S TALKING ─────────────────────────────────────────
# Sign up: https://account.africastalking.com/auth/register
# [REQUIRED][SERVER] for live M-Pesa STK push and USSD
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=


# ─── M-PESA DARAJA (direct — optional if using Kotani/AT) ─────
# Sign up: https://developer.safaricom.co.ke
# [OPTIONAL][SERVER]
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://baraza-protocol.vercel.app/api/webhooks/africastalking
# Simulator — always false in production; set true only for load tests
MPESA_SIMULATOR_ENABLED=false
MPESA_SIMULATOR_SECRET=


# ─── SOLANA (governance layer) ────────────────────────────────
# [REQUIRED][CLIENT]
VITE_SOLANA_NETWORK=mainnet-beta
VITE_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Deployed Anchor program IDs (set after anchor deploy)
VITE_COMMUNITY_REGISTRY_PROGRAM_ID=
VITE_GOVERNANCE_PROGRAM_ID=DzMhDFtq2s2bUn4LNDVzDLLnbbRQ8jW1FKeWPQDDq25A
VITE_MEMBERSHIP_PROGRAM_ID=
VITE_PAYMENT_ATTESTATION_PROGRAM_ID=
VITE_TREASURY_VAULT_PROGRAM_ID=


# ─── WALLETS ──────────────────────────────────────────────────
# WalletConnect — https://cloud.walletconnect.com
# [REQUIRED][CLIENT]
VITE_WALLETCONNECT_PROJECT_ID=

# Privy — https://dashboard.privy.io (phone OTP / MPC wallets)
# [OPTIONAL][CLIENT+SERVER]
VITE_PRIVY_APP_ID=
PRIVY_APP_SECRET=


# ─── BASE CHAIN GOVERNANCE ────────────────────────────────────
# The Manager factory is pre-deployed at well-known addresses:
#   Base mainnet  (8453):  0x3ac0e64fe2931f8e082c6bb29283540de9b5371c
#   Base Sepolia (84532):  0x550c326d688fd51ae65ac6a2d48749e631023a03
# Only set VITE_BASE_MANAGER_ADDRESS to override the default.
# [OPTIONAL][CLIENT]
VITE_BASE_MANAGER_ADDRESS=
# Set true to target Base Sepolia instead of Base mainnet
VITE_BASE_TESTNET=false
# Per-community contracts — set after deploying a Baraza DAO via Manager.deploy()
# [OPTIONAL][CLIENT]
VITE_BASE_GOVERNOR_ADDRESS=
VITE_BASE_TOKEN_ADDRESS=
VITE_BASE_TREASURY_ADDRESS=


# ─── EVM CHAINS (secondary rails) ────────────────────────────
# [OPTIONAL][CLIENT] RPC endpoints for each supported EVM chain
VITE_ETH_RPC_URL=
VITE_BASE_RPC_URL=
VITE_ARBITRUM_RPC_URL=
VITE_OPTIMISM_RPC_URL=
VITE_POLYGON_RPC_URL=
VITE_BNB_RPC_URL=
VITE_CELO_RPC_URL=
VITE_XDC_RPC_URL=

# [OPTIONAL][CLIENT] On-chain contract addresses per chain
VITE_ETH_CONTRACT_ADDR=
VITE_BASE_CONTRACT_ADDR=
VITE_ARBITRUM_CONTRACT_ADDR=
VITE_OPTIMISM_CONTRACT_ADDR=
VITE_POLYGON_CONTRACT_ADDR=
VITE_BNB_CONTRACT_ADDR=
VITE_CELO_CONTRACT_ADDR=
VITE_XDC_CONTRACT_ADDR=


# ─── GOODDOLLAR ───────────────────────────────────────────────
# [OPTIONAL][CLIENT] Set true only for GoodDollar demo mode
VITE_GOODDOLLAR_ENABLED=false
VITE_GOODDOLLAR_TOKEN_ADDRESS=
VITE_GOODDOLLAR_IDENTITY_ADDRESS=


# ─── ADMIN ────────────────────────────────────────────────────
# [REQUIRED][CLIENT] Comma-separated wallet addresses with admin access
VITE_ADMIN_WALLETS=
VITE_ADMIN_NFT_THRESHOLD=1
VITE_ADMIN_NFT_COUNT=0


# ─── AI AGENT (Asha — community brain) ───────────────────────
# [REQUIRED][SERVER] Anthropic API key for Asha community brain
# Get yours: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=


# ─── CRON ─────────────────────────────────────────────────────
# [REQUIRED][SERVER] Vercel Cron auth token — must match vercel.json cron route
# Generate: openssl rand -hex 32
CRON_SECRET=


# ─── NOTIFICATIONS (optional) ─────────────────────────────────
# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@baraza-protocol.vercel.app

# Community channels (optional)
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
