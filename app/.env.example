# Baraza Protocol - Environment Variables
# Copy to .env.local for local work. Never commit real secrets.

# Site URLs
VITE_SITE_URL=https://baraza-protocol.vercel.app
NEXT_PUBLIC_SITE_URL=https://baraza-protocol.vercel.app

# Solana testnet/devnet
VITE_SOLANA_NETWORK=devnet
VITE_RPC_ENDPOINT=https://api.devnet.solana.com
VITE_COMMUNITY_REGISTRY_PROGRAM_ID=<solana-devnet-program-id>
VITE_GOVERNANCE_PROGRAM_ID=<solana-devnet-program-id>
VITE_MEMBERSHIP_PROGRAM_ID=<solana-devnet-program-id>
VITE_PAYMENT_ATTESTATION_PROGRAM_ID=<solana-devnet-program-id>
VITE_TREASURY_VAULT_PROGRAM_ID=<solana-devnet-program-id>
VITE_PROGRAM_ID=

# Stellar testnet
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_STELLAR_TREASURY_ACCOUNT=<stellar-testnet-g-account>
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org
STELLAR_TREASURY_ACCOUNT=<stellar-testnet-g-account>

# BRZA token
VITE_BRZA_ISSUER_ADDRESS=
VITE_BRZA_DISTRIBUTOR_ADDRESS=

# Kotani Pay + Minisend
VITE_KOTANI_PAY_API_KEY=
VITE_KOTANI_API_BASE=https://api.kotanipay.com
VITE_MINISEND_API_KEY=
VITE_MINISEND_API_BASE=https://api.minisend.xyz

# GoodDollar — always false unless demo
VITE_GOODDOLLAR_ENABLED=false

# EVM testnets
VITE_ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<alchemy-key>
VITE_BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/<alchemy-key>
VITE_ARBITRUM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<alchemy-key>
VITE_OPTIMISM_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/<alchemy-key>
VITE_POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/<alchemy-key>
VITE_BNB_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
VITE_CELO_RPC_URL=https://alfajores-forno.celo-testnet.org
VITE_XDC_RPC_URL=https://erpc.apothem.network

# EVM / Celo contract addresses
VITE_ETH_CONTRACT_ADDR=<ethereum-sepolia-contract-address>
VITE_BASE_CONTRACT_ADDR=<base-sepolia-contract-address>
VITE_ARBITRUM_CONTRACT_ADDR=<arbitrum-sepolia-contract-address>
VITE_OPTIMISM_CONTRACT_ADDR=<op-sepolia-contract-address>
VITE_POLYGON_CONTRACT_ADDR=<polygon-amoy-contract-address>
VITE_BNB_CONTRACT_ADDR=<bnb-testnet-contract-address>
VITE_CELO_CONTRACT_ADDR=<celo-alfajores-contract-address>
VITE_XDC_CONTRACT_ADDR=<xdc-apothem-contract-address>

# GoodDollar / Celo
VITE_GOODDOLLAR_TOKEN_ADDRESS=<alfajores-g-dollar-token-address>
VITE_GOODDOLLAR_IDENTITY_ADDRESS=<alfajores-gooddollar-identity-address>
GOODDOLLAR_API_KEY=<server-side-gooddollar-key>

# Wallet onboarding
VITE_WALLETCONNECT_PROJECT_ID=<walletconnect-project-id>
VITE_PRIVY_APP_ID=<privy-app-id>
PRIVY_APP_SECRET=<server-side-privy-secret>

# Supabase persistence
VITE_SUPABASE_URL=<supabase-url>
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_URL=<supabase-url>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Admin / token gate
VITE_ADMIN_WALLETS=<comma-separated-admin-wallets>
VITE_ADMIN_NFT_THRESHOLD=1
VITE_ADMIN_NFT_COUNT=0

# M-Pesa Daraja
MPESA_CONSUMER_KEY=<daraja-sandbox-consumer-key>
MPESA_CONSUMER_SECRET=<daraja-sandbox-consumer-secret>
MPESA_SHORTCODE=<daraja-sandbox-shortcode>
MPESA_PASSKEY=<daraja-sandbox-passkey>
MPESA_CALLBACK_URL=https://baraza-protocol.vercel.app/api/mpesa/callback
MPESA_SIMULATOR_ENABLED=false
MPESA_SIMULATOR_SECRET=<local-simulator-secret>

# Notifications
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=<twilio-sms-number>
SENDGRID_API_KEY=<sendgrid-api-key>
SENDGRID_FROM_EMAIL=no-reply@baraza-protocol.vercel.app
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
DISCORD_WEBHOOK_URL=<discord-webhook-url>

# Storage and indexing
IPFS_NODE_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=<ipfs-project-id>
IPFS_PROJECT_SECRET=<ipfs-project-secret>
PINATA_API_KEY=<pinata-api-key>
PINATA_SECRET_API_KEY=<pinata-secret-api-key>
FILECOIN_API_KEY=<filecoin-api-key>
THE_GRAPH_API_KEY=<the-graph-api-key>
VITE_SUBGRAPH_URL=<subgraph-query-url>

# Chainlink
CHAINLINK_CCIP_ROUTER=<testnet-ccip-router-address>
CHAINLINK_PRICE_FEED_KES_USD=<testnet-price-feed-address>

# Cron / jobs
CRON_SECRET=<vercel-cron-secret>
