# Baraza Protocol — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.
# All VITE_ vars are bundled into the browser — never put secrets in VITE_ vars.
# Server-side secrets go into Vercel project settings (Encrypted).
# ─────────────────────────────────────────────────────────────────────────────


# ── Site ─────────────────────────────────────────────────────────────────────

VITE_SITE_URL=https://baraza-protocol.vercel.app


# ── Supabase (off-chain database) ─────────────────────────────────────────────
# Sign up  → https://supabase.com
# Keys     → Project Settings → API
# Run all files in supabase/migrations/ in order before first use.

# Client vars (safe to bundle — anon key has RLS-gated access only):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon-key...

# Server-only vars (set as Encrypted in Vercel project settings):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...


# ── Africa's Talking (SMS · USSD · M-Pesa STK push) ──────────────────────────
# Sign up  → https://africastalking.com
# Keys     → Dashboard → Settings → API Key
# Sandbox username is always "sandbox"; production username is your app name.

AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key
# Sender ID shown on member SMS. Leave blank to use AT default short-code.
AT_SENDER_ID=Baraza


# ── M-Pesa Daraja (Safaricom STK push — direct API) ──────────────────────────
# Sign up  → https://developer.safaricom.co.ke
# App      → Create App → enable M-Pesa Express (STK Push)

MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
# Paybill or till number assigned to your Daraja app.
MPESA_SHORTCODE=174379
# Lipa Na M-Pesa online passkey (from Daraja app dashboard).
MPESA_PASSKEY=your-mpesa-passkey
# Publicly reachable URL Safaricom POSTs STK results to.
# Use a Vercel preview URL or ngrok tunnel during local testing.
MPESA_CALLBACK_URL=https://baraza-protocol.vercel.app/api/mpesa/callback

# Simulator controls (non-production environments only).
# Set MPESA_SIMULATOR_ENABLED=true to allow /api/mpesa/simulate in production.
MPESA_SIMULATOR_ENABLED=false
MPESA_SIMULATOR_SECRET=


# ── Stellar (Horizon · Soroban RPC · settlement rail) ────────────────────────
# Testnet endpoints are public — no signup needed for testnet.
# Mainnet: use Horizon API → https://horizon.stellar.org
#          or a paid provider like https://lobstr.co / https://nownodes.io

# Server-side vars:
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org
# Optional: require verified XLM payments to credit this account.
STELLAR_TREASURY_ACCOUNT=

# Client-side vars (bundled — public endpoints only):
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Mainnet passphrase (swap when going live):
# VITE_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015


# ── Solana (RPC endpoint · Anchor program IDs) ───────────────────────────────
# Free devnet RPC  → https://api.devnet.solana.com  (rate-limited)
# Helius (recommended, generous free tier) → https://helius.dev
# QuickNode        → https://quicknode.com

VITE_SOLANA_NETWORK=devnet
VITE_RPC_ENDPOINT=https://api.devnet.solana.com

# Anchor program IDs deployed on devnet.
# Update these once programs are deployed to mainnet-beta.
VITE_COMMUNITY_REGISTRY_PROGRAM_ID=Ggj4e8YjiDdpbcudKz6BLx5arT9nf7BQR498VnLXd7eD
VITE_GOVERNANCE_PROGRAM_ID=DzMhDFtq2s2bUn4LNDVzDLLnbbRQ8jW1FKeWPQDDq25A
VITE_MEMBERSHIP_PROGRAM_ID=34MQRw2XSScvMYTiyYLix31qnrmh9vARwpmXM6ycNtuK
VITE_PAYMENT_ATTESTATION_PROGRAM_ID=Az2CdHJFBLxRY6pigkYSsni6A8N1dQo3JUp3d62NGVpT
VITE_TREASURY_VAULT_PROGRAM_ID=ApPdkfooQLdVN8gAXRnddbtttruYNihiwjanYtXUnxYy


# ── EVM chains (read-only RPC for governance contract rails) ──────────────────
# Alchemy  → https://alchemy.com  (free tier — Base, Arbitrum, Optimism, Celo)
# Infura   → https://infura.io
# QuickNode → https://quicknode.com

VITE_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key
VITE_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
VITE_ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-key
VITE_OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/your-key
VITE_CELO_RPC_URL=https://celo-mainnet.g.alchemy.com/v2/your-key


# ── WalletConnect (mobile wallet deep-link) ───────────────────────────────────
# Sign up  → https://cloud.walletconnect.com
# Create a project → copy the Project ID.

VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id


# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated Solana base58 pubkeys with access to /admin.

VITE_ADMIN_WALLETS=


# ── Cron secret ───────────────────────────────────────────────────────────────
# Vercel Cron sends this as "Authorization: Bearer <CRON_SECRET>" automatically.
# Generate: openssl rand -hex 32
# Set as Encrypted in Vercel project settings — never commit this value.

CRON_SECRET=your-cron-secret-hex
