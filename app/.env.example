# Baraza Protocol — Environment Variables
# Copy to .env.local and fill in your values

# Solana network: mainnet | devnet | testnet (defaults to devnet)
# Drives the wallet adapter network, expected genesis hash, and the
# "Wrong network" label users see in the wallet pill.
VITE_SOLANA_NETWORK=devnet

# Solana RPC endpoint (optional — falls back to public clusterApiUrl
# for VITE_SOLANA_NETWORK above)
VITE_RPC_ENDPOINT=

# Baraza on-chain program ID for the selected network
VITE_PROGRAM_ID=

# Supabase (optional — for off-chain community metadata)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Comma-separated list of Solana wallet addresses allowed to view /admin.
# Empty (default) hides the page from everyone with an "Access restricted" screen.
VITE_ADMIN_WALLETS=

# ─────────────────────── Server-side (Vercel Functions) ───────────────────────
# Set these in Vercel project settings, NOT in .env.local — they're secrets and
# must not ship to the browser. Used by /api/mpesa/simulate.ts to write
# payment_orders rows. Leave unset to run the simulator without persistence.

# Supabase service-role key (server-only, never VITE_-prefixed).
# Find at: Supabase dashboard → Project settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL (same as VITE_SUPABASE_URL above; duplicated server-side
# so the Edge function can read it without exposing the VITE_ prefix to clients).
SUPABASE_URL=
