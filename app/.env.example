# Baraza Protocol - Environment Variables
# Copy to .env.local and fill in real values locally.

VITE_SITE_URL=https://baraza-protocol.vercel.app
# Compatibility note for reviewers coming from Next.js checklists.
NEXT_PUBLIC_SITE_URL=https://baraza-protocol.vercel.app

# Solana network: mainnet | mainnet-beta | devnet | testnet
VITE_SOLANA_NETWORK=devnet

# Solana RPC endpoint. Use a dedicated provider key for real testnet review.
VITE_RPC_ENDPOINT=https://api.devnet.solana.com

# Stellar settlement rail. Optional; enables Profile balance and tx checks.
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Solana program IDs for the selected network.
VITE_COMMUNITY_REGISTRY_PROGRAM_ID=Ggj4e8YjiDdpbcudKz6BLx5arT9nf7BQR498VnLXd7eD
VITE_GOVERNANCE_PROGRAM_ID=DzMhDFtq2s2bUn4LNDVzDLLnbbRQ8jW1FKeWPQDDq25A
VITE_MEMBERSHIP_PROGRAM_ID=34MQRw2XSScvMYTiyYLix31qnrmh9vARwpmXM6ycNtuK
VITE_PAYMENT_ATTESTATION_PROGRAM_ID=Az2CdHJFBLxRY6pigkYSsni6A8N1dQo3JUp3d62NGVpT
VITE_TREASURY_VAULT_PROGRAM_ID=ApPdkfooQLdVN8gAXRnddbtttruYNihiwjanYtXUnxYy

# Deprecated compatibility variable. Prefer the five explicit program ID vars above.
VITE_PROGRAM_ID=

# Optional WalletConnect project ID for mobile wallet adapters.
VITE_WALLETCONNECT_PROJECT_ID=

# EVM testnet RPC endpoints for governance-contract review rails.
VITE_BASE_RPC_URL=
VITE_ETH_RPC_URL=
VITE_ARBITRUM_RPC_URL=
VITE_OPTIMISM_RPC_URL=
VITE_CELO_RPC_URL=

# Optional Supabase client config for off-chain community metadata.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Comma-separated Solana wallet addresses allowed to view /admin.
VITE_ADMIN_WALLETS=

# ─────────────────────── Server-side secrets (Vercel Functions) ───────────────
# Set these in Vercel project settings or a non-committed .env.local.
# NEVER prefix with VITE_ — that would expose them to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org
# Optional: require verified Stellar payments to land in this account.
STELLAR_TREASURY_ACCOUNT=

# M-Pesa Daraja sandbox / production credentials.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
