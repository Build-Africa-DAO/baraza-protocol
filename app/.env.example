# Baraza Protocol — Environment Variables
# Copy to .env.local and fill in your values

# Solana RPC endpoint (optional — falls back to public devnet)
VITE_RPC_ENDPOINT=

# Baraza on-chain program ID (Devnet)
VITE_PROGRAM_ID=

# Supabase (optional — for off-chain community metadata)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
