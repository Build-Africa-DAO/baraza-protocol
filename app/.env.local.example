# Baraza Protocol — Local Dev Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in your own values. Never commit .env.local.
# This file uses sandbox/testnet defaults so the app runs without real money.
# ─────────────────────────────────────────────────────────────────────────────

VITE_SITE_URL=http://localhost:5173

# Supabase (optional in local dev — app falls back to mock data without it)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Africa's Talking sandbox (username is always "sandbox" in sandbox mode)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=Baraza

# M-Pesa Daraja sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:5173/api/mpesa/callback
MPESA_SIMULATOR_ENABLED=true
MPESA_SIMULATOR_SECRET=

# Stellar testnet
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org
STELLAR_TREASURY_ACCOUNT=
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Solana devnet
VITE_SOLANA_NETWORK=devnet
VITE_RPC_ENDPOINT=https://api.devnet.solana.com
VITE_COMMUNITY_REGISTRY_PROGRAM_ID=Ggj4e8YjiDdpbcudKz6BLx5arT9nf7BQR498VnLXd7eD
VITE_GOVERNANCE_PROGRAM_ID=DzMhDFtq2s2bUn4LNDVzDLLnbbRQ8jW1FKeWPQDDq25A
VITE_MEMBERSHIP_PROGRAM_ID=34MQRw2XSScvMYTiyYLix31qnrmh9vARwpmXM6ycNtuK
VITE_PAYMENT_ATTESTATION_PROGRAM_ID=Az2CdHJFBLxRY6pigkYSsni6A8N1dQo3JUp3d62NGVpT
VITE_TREASURY_VAULT_PROGRAM_ID=ApPdkfooQLdVN8gAXRnddbtttruYNihiwjanYtXUnxYy

# EVM chains (leave blank to use public RPC fallbacks)
VITE_BASE_RPC_URL=
VITE_ETH_RPC_URL=
VITE_ARBITRUM_RPC_URL=
VITE_OPTIMISM_RPC_URL=
VITE_CELO_RPC_URL=

# WalletConnect (optional for local dev)
VITE_WALLETCONNECT_PROJECT_ID=

# Admin wallets
VITE_ADMIN_WALLETS=

# Cron (leave blank in local dev — auth is skipped when CRON_SECRET is unset)
CRON_SECRET=
