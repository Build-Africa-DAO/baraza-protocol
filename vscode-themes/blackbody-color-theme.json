    "terminal.selectionBackground": "#9DD9D240",
    "terminal.ansiBlack": "#392F5A",
    "terminal.ansiBrightBlack": "#6D648A",
    "terminal.ansiBlue": "#506FA0",
    "terminal.ansiBrightBlue": "#9DD9D2",
    "terminal.ansiCyan": "#6EBFB8",
    "terminal.ansiBrightCyan": "#BFEAE5",
    "terminal.ansiGreen": "#78A87F",
    "terminal.ansiBrightGreen": "#A7D7BC",
    "terminal.ansiYellow": "#D5A93D",
    "terminal.ansiBrightYellow": "#F4D06F",
    "terminal.ansiRed": "#D65F17",
    "terminal.ansiBrightRed": "#FF8811",
    "terminal.ansiMagenta": "#8C6BB1",
    "terminal.ansiBrightMagenta": "#B0A8C8",
