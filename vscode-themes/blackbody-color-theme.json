    "minimap.selectionHighlight": "#9DD9D240",
    "minimap.findMatchHighlight": "#F4D06F66",
    "minimap.errorHighlight": "#FF8811",
    "minimap.warningHighlight": "#F4D06F",

    "gitDecoration.addedResourceForeground": "#8C6E19",
    "gitDecoration.modifiedResourceForeground": "#4B9B94",
    "gitDecoration.deletedResourceForeground": "#D65F17",
    "gitDecoration.untrackedResourceForeground": "#8C6E19",
    "gitDecoration.ignoredResourceForeground": "#B0A8C8",
    "diffEditor.insertedTextBackground": "#9DD9D233",
    "diffEditor.removedTextBackground": "#FF881126",
    "diffEditor.insertedLineBackground": "#9DD9D21F",
    "diffEditor.removedLineBackground": "#FF88111A",

    "debugToolBar.background": "#FFF8F0",
    "debugToolBar.border": "#EEF6F5",
    "debugIcon.startForeground": "#8C6E19",
    "debugIcon.pauseForeground": "#D5A93D",
    "debugIcon.stopForeground": "#D65F17",
    "debugIcon.restartForeground": "#5FAFA7",
    "debugIcon.stepOverForeground": "#392F5A",
    "debugIcon.stepIntoForeground": "#392F5A",
    "debugIcon.stepOutForeground": "#392F5A",
    "debugIcon.disconnectForeground": "#FF8811",

    "notifications.background": "#FFFFFF",
    "notifications.foreground": "#392F5A",
    "notifications.border": "#EEF6F5",
    "notificationLink.foreground": "#FF8811",
    "extensionButton.prominentBackground": "#392F5A",
    "extensionButton.prominentForeground": "#FFF8F0",
    "extensionButton.prominentHoverBackground": "#4A3E70"
  },
  "tokenColors": [
    {
      "name": "Base text",
      "scope": [
        "source",
        "text",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#392F5A"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B0A8C8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "identifier",
        "entity.name.variable",
        "meta.object-literal.key",
        "support.variable"
      ],
      "settings": {
        "foreground": "#392F5A"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type",
        "meta.type.annotation"
      ],
      "settings": {
        "foreground": "#5FAFA7"
      }
    },
    {
      "name": "Strings with cool token field",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#7C6A46",
        "background": "#EEF6F5"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "variable.other.object.property",
        "meta.method-call"
      ],
      "settings": {
        "foreground": "#B88918"
      }
    },
    {
      "name": "Keywords and operators",
      "scope": [
        "keyword",
        "keyword.operator",
        "storage.modifier",
        "storage.type.function",
        "punctuation.separator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#FF8811"
      }
    },
    {
      "name": "Constants, numbers, booleans",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#D66F12"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#8C6BB1"
      }
    },
    {
      "name": "Markup tags and attributes",
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#FF8811"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "markup.heading punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#392F5A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#5FAFA7"
      }
    },
    {
      "name": "Inserted markup",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#8C6E19"
      }
    },
    {
      "name": "Deleted markup",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#D65F17"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#6D648A"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#C95000"
      }
    }
  ],
  "semanticTokenColors": {
    "variable": "#392F5A",
    "parameter": "#392F5A",
    "property": "#392F5A",
    "enumMember": "#D66F12",
    "class": "#5FAFA7",
    "interface": "#5FAFA7",
    "struct": "#5FAFA7",
    "enum": "#5FAFA7",
    "namespace": "#5FAFA7",
    "type": "#5FAFA7",
    "typeParameter": "#5FAFA7",
    "function": "#B88918",
    "method": "#B88918",
    "macro": "#B88918",
    "keyword": "#FF8811",
    "operator": "#FF8811",
    "string": {
      "foreground": "#7C6A46",
      "background": "#EEF6F5"
    },
    "number": "#D66F12",
    "regexp": "#8C6BB1",
    "comment": {
      "foreground": "#B0A8C8",
      "italic": true
    },
    "*.declaration": {
      "bold": true
    },
    "*.readonly": {
      "foreground": "#6D648A"
    },
    "*.deprecated": {
      "strikethrough": true
    }
  }
}
