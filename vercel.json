{
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "installCommand": "echo skip",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/)(?!_vercel/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "functions": {
    "api/ussd/index.ts": {
      "maxDuration": 5
    },
    "api/mpesa/simulate.ts": {
      "maxDuration": 15
    },
    "api/membership/activate.ts": {
      "maxDuration": 30
    },
    "api/stellar/verify-payment.ts": {
      "maxDuration": 30
    },
    "api/payment-orders/status.ts": {
      "maxDuration": 10
    },
    "api/cron/promote-orders.ts": {
      "maxDuration": 60
    },
    "api/cron/settle-retro-allocations.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/promote-orders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/settle-retro-allocations",
      "schedule": "0 0 * * *"
    }
  ]
}
